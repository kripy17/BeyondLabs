# BeyondLabs backend example environment.
# The backend runs with safe local defaults and does not require secrets.
# Copy to backend/.env — run.sh / run.ps1 do this automatically if missing.

# Read by run.sh / run.ps1 to launch uvicorn. Falls back to 127.0.0.1:8000
# if unset or this file doesn't exist.
BEYONDLABS_BACKEND_HOST=127.0.0.1
BEYONDLABS_BACKEND_PORT=8000

# Read directly by backend/app/main.py (os.environ) to configure allowed
# CORS origins — comma-separated. Falls back to the local Vite dev origin
# if unset. In Docker, docker-compose.yml sets this explicitly since the
# frontend container serves on a different port (see docker-compose.yml).
# Keep this local unless you intentionally expose the backend.
BEYONDLABS_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
