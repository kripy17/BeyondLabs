# BeyondArch backend example environment.
# The backend currently runs with safe local defaults and does not require secrets.

# Uvicorn defaults used by run.sh / run.ps1.
BEYONDARCH_BACKEND_HOST=127.0.0.1
BEYONDARCH_BACKEND_PORT=8000

# Comma-separated browser origins allowed by local development.
# Keep this local unless you intentionally expose the backend.
BEYONDARCH_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
